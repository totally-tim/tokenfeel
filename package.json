{
  "name": "tokenfeel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static local LLM inference feel simulator with repo-backed benchmark data.",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totally-tim/tokenfeel.git"
  },
  "bugs": {
    "url": "https://github.com/totally-tim/tokenfeel/issues"
  },
  "homepage": "https://totally-tim.github.io/tokenfeel/",
  "bin": {
    "tokenfeel-convert": "./scripts/convert-llama-bench.ts"
  },
  "scripts": {
    "dev": "tsx scripts/build-static-catalog.ts && vite --host 127.0.0.1",
    "build": "tsx scripts/build-static-catalog.ts && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:data": "tsx scripts/validate-data.ts",
    "prune:data": "tsx scripts/prune-catalog.ts",
    "convert:llama-bench": "tsx scripts/convert-llama-bench.ts",
    "import:omlx": "tsx scripts/import-omlx-benchmarks.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.2",
    "lucide-react": "0.468.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "4.3.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "22.12.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "5.0.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  }
}
